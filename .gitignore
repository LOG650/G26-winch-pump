# ── Data (konfidensielt / store filer) ───────────────────────────────────────
# Hver snapshot lagres i egen dato-mappe under 004 data/. Hele mappen er
# konfidensiell og skal ikke committes.
004 data/*/
*.csv
*.xlsx
*.xls

# Transkriberingsskript (inneholder rådata inline – konfidensielt)
_transcribe_*.py

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Miljøvariabler og hemmeligheter ──────────────────────────────────────────
.env
.env.*
*.key
secrets.*

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Microsoft Office midlertidige filer ──────────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
