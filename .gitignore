# ── Data ─────────────────────────────────────────────────────────────────────
# 004 data/ inneholder ukentlige Power BI-snapshots fra Motive Norway.
# Mappen er gjort tilgjengelig offentlig etter godkjenning fra Motive og
# faglærer for å la sensor kunne reprodusere analysen. CSV- og PNG-filer
# samt transkriberings-skript committes derfor.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Miljøvariabler og hemmeligheter ──────────────────────────────────────────
.env
.env.*
*.key
secrets.*

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Microsoft Office midlertidige filer ──────────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
